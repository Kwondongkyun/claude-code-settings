{
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "OTEL_EXPORTER_OTLP_ENDPOINT": "http://43.201.162.58:4317",
    "OTEL_EXPORTER_OTLP_PROTOCOL": "grpc",
    "OTEL_METRIC_EXPORT_INTERVAL": "60000",
    "OTEL_METRICS_EXPORTER": "otlp",
    "OTEL_METRICS_INCLUDE_SESSION_ID": "false",
    "OTEL_RESOURCE_ATTRIBUTES": "plan=TeamPremium,team=DEV",
    "OTEL_SERVICE_NAME": "claude-code-eren.kwon"
  },
  "permissions": {
    "allow": [
      "Bash(*)",
      "WebSearch",
      "mcp__playwright",
      "mcp__pencil"
    ],
    "deny": [
      "Bash(*rm -rf *)",
      "Bash(*killall *)",
      "Bash(*sudo *)",
      "Bash(*git push --force*)",
      "Bash(*npm publish*)",
      "Bash(*dd *)",
      "Bash(*mkfs *)",
      "Bash(*shutdown*)",
      "Bash(*reboot*)",
      "Bash(*poweroff*)",
      "Bash(*fdisk*)",
      "Bash(*diskutil erase*)",
      "Bash(*diskutil partitionDisk*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(~/.ssh/**)"
    ],
    "ask": [
      "Bash(*rm *)",
      "Bash(*curl *)",
      "Bash(*wget *)",
      "Bash(*git push *)",
      "Bash(*git reset --hard*)",
      "Bash(*git clean -f*)",
      "Bash(*pkill *)",
      "Bash(*chmod *)",
      "Bash(*chown *)",
      "Bash(*ssh *)",
      "Bash(*scp *)",
      "Bash(*launchctl *)",
      "Bash(*crontab *)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/init-context-files.sh",
            "statusMessage": "컨텍스트 파일 확인 중..."
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/pre-compact-marker.sh",
            "statusMessage": "compact 마커 생성..."
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/post-compact-reminder.sh",
            "statusMessage": "컨텍스트 복구 중..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/post-compact-reminder.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/lint-fix.sh \"$CLAUDE_FILE_PATH\"",
            "statusMessage": "린트 자동 수정 중..."
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/notify.sh '⚠️ Claude Code 중단' 'API 에러로 작업이 멈췄습니다'",
            "statusMessage": "에러 알림 전송..."
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "code-review@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "planning-with-files@planning-with-files": false,
    "ralph-loop@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "telegram@claude-plugins-official": true,
    "discord@claude-plugins-official": true,
    "last30days@last30days-skill": false
  },
  "language": "Korean",
  "effortLevel": "medium",
  "mcpServers": {
    "playwright": {
      "args": [
        "@playwright/mcp@0.0.68"
      ],
      "command": "npx"
    },
    "pencil": {
      "command": "/Applications/Pencil.app/Contents/Resources/app.asar.unpacked/out/mcp-server-darwin-arm64",
      "args": [
        "--app",
        "desktop"
      ],
      "env": {},
      "type": "stdio"
    }
  },
  "teammateMode": "auto"
}
